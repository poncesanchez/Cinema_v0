# Docker Compose — desarrollo local simulando producción
# Uso: docker compose --env-file .env.prod up --build -d
SPRING_PROFILES_ACTIVE=prod

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cinebook
SPRING_DATASOURCE_USERNAME=cinebook
SPRING_DATASOURCE_PASSWORD=cinebook
POSTGRES_DB=cinebook
POSTGRES_USER=cinebook
POSTGRES_PASSWORD=cinebook

VITE_API_URL=http://localhost:8082
VITE_BUILD_MODE=production

PELICULAS_PORT=8082
FRONTEND_PORT=3000
